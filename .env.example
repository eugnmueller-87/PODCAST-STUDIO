# PodcastIQ — API Keys
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# LLM providers — add the key for whichever you want to use
ANTHROPIC_API_KEY=sk-ant-...   # Anthropic (Claude) — default
OPENAI_API_KEY=sk-...          # OpenAI (GPT-4o) — select in UI

# Required for ElevenLabs voice (Alex — female host)
# Get your key at https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=...
